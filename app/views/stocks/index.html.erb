<div style="max-width: 1280px; margin: 0 auto; padding: 2.5rem 1.5rem;">

  <%# ── Page header ── %>
  <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem;">
    <div>
      <h1 class="tw-font-custom" style="color: #EAECEF; font-size: 1.75rem; letter-spacing: 0.1em;
                  text-transform: uppercase; margin: 0 0 0.25rem;">Markets</h1>
      <p style="color: #929AA5; font-size: 0.82rem; margin: 0;">
        Browse stocks and view live candlestick charts.
      </p>
    </div>
  </div>

  <%# ── Market table ── %>
  <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
              border-radius: 12px; overflow: hidden;">

    <%# Table header %>
    <div style="display: grid; grid-template-columns: 2rem 1fr 2fr 1fr 1fr 1fr; gap: 1rem;
                padding: 0.75rem 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.07);">
      <span style="color: #929AA5; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em;">#</span>
      <span style="color: #929AA5; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em;">Symbol</span>
      <span style="color: #929AA5; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em;">Company</span>
      <span style="color: #929AA5; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; text-align: right;">Price</span>
      <span style="color: #929AA5; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; text-align: right;">Change</span>
      <span style="color: #929AA5; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; text-align: right;">Chart</span>
    </div>

    <% if @stocks.any? %>
      <% @stocks.each_with_index do |stock, i| %>
        <% day_open = @day_open[stock.ticker].to_f %>
        <% cur      = stock.last_price.to_f %>
        <% chg      = day_open > 0 ? cur - day_open : 0 %>
        <% chg_pct  = day_open > 0 ? (chg / day_open * 100) : 0 %>
        <% chg_col  = chg >= 0 ? '#2EBD85' : '#F6465D' %>
        <% chg_sign = chg >= 0 ? '+' : '' %>

        <div data-ticker="<%= stock.ticker %>"
             data-day-open="<%= day_open %>"
             style="display: grid; grid-template-columns: 2rem 1fr 2fr 1fr 1fr 1fr; gap: 1rem;
                    padding: 0.9rem 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.04);
                    align-items: center; transition: background 0.15s;"
             onmouseover="this.style.background='rgba(255,255,255,0.03)'"
             onmouseout="this.style.background='transparent'">

          <span style="color: #929AA5; font-size: 0.82rem;"><%= i + 1 %></span>

          <div style="display: flex; align-items: center; gap: 0.6rem;">
            <div style="width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0;
                        background: rgba(20,184,166,0.1); border: 1px solid rgba(20,184,166,0.2);
                        display: flex; align-items: center; justify-content: center;
                        font-size: 0.6rem; font-weight: 700; color: #14B8A6; overflow: hidden;">
              <img src="<%= stock_logo_url(stock.ticker) %>"
                   alt="<%= stock.ticker %>"
                   style="width: 22px; height: 22px; object-fit: contain; border-radius: 3px;"
                   onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
              <span style="display: none; width: 100%; height: 100%; align-items: center;
                           justify-content: center; font-size: 0.6rem; font-weight: 700; color: #14B8A6;">
                <%= stock.ticker.first(2).upcase %>
              </span>
            </div>
            <span style="color: #EAECEF; font-size: 0.9rem; font-weight: 700;
                         letter-spacing: 0.05em;"><%= stock.ticker %></span>
          </div>

          <% if stock_website_url(stock.ticker) %>
            <%= link_to stock.company_name, stock_website_url(stock.ticker), target: "_blank", rel: "noopener noreferrer",
                style: "color: #929AA5; font-size: 0.875rem; text-decoration: underline;
                        text-decoration-color: rgba(147,154,165,0.4); text-underline-offset: 3px;
                        transition: color 0.2s;",
                onmouseover: "this.style.color='#EAECEF'",
                onmouseout:  "this.style.color='#929AA5'" %>
          <% else %>
            <span style="color: #929AA5; font-size: 0.875rem;"><%= stock.company_name %></span>
          <% end %>

          <%# Price cell %>
          <div class="stock-price" style="text-align: right; color: #EAECEF; font-size: 0.9rem; font-weight: 700;">
            <%= cur > 0 ? "$#{"%.2f" % cur}" : "—" %>
          </div>

          <%# Change cell %>
          <div class="stock-change" style="text-align: right; font-size: 0.82rem; font-weight: 600; color: <%= chg_col %>;">
            <% if day_open > 0 %>
              <div class="chg-abs"><%= chg_sign %><%= "%.2f" % chg.abs %></div>
              <div class="chg-pct" style="font-size: 0.72rem; opacity: 0.85;">(<%= chg_sign %><%= "%.2f" % chg_pct.abs %>%)</div>
            <% else %>
              —
            <% end %>
          </div>

          <%# View chart link %>
          <div style="text-align: right;">
            <%= link_to "View Chart →", stock_path(stock),
                style: "color: #14B8A6; text-decoration: none; font-size: 0.82rem; font-weight: 600;
                        transition: color 0.2s;",
                data: { turbo: false },
                onmouseover: "this.style.color='#0d9488'",
                onmouseout:  "this.style.color='#14B8A6'" %>
          </div>

        </div>
      <% end %>
    <% else %>
      <div style="padding: 4rem; text-align: center;">
        <p style="color: #929AA5; font-size: 0.9rem; margin: 0;">No stocks available yet.</p>
      </div>
    <% end %>

  </div>

</div>

<script>
(function () {
  var _timer = null;

  function startPolling() {
    if (_timer) { clearInterval(_timer); _timer = null; }

    var rows = document.querySelectorAll('[data-ticker][data-day-open]');
    if (!rows.length) return;

    var tickers = [];
    rows.forEach(function(r) { tickers.push(r.getAttribute('data-ticker')); });
    var tickerStr = tickers.join(',');

    function fmt2(n) {
      return Math.abs(n).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function refresh() {
      var xhr = new XMLHttpRequest();
      xhr.open('GET', '/stocks/prices?tickers=' + tickerStr);
      xhr.setRequestHeader('Accept', 'application/json');
      xhr.onload = function () {
        if (xhr.status !== 200) return;
        try { var prices = JSON.parse(xhr.responseText); } catch (e) { return; }

        rows.forEach(function(row) {
          var ticker  = row.getAttribute('data-ticker');
          var dayOpen = parseFloat(row.getAttribute('data-day-open'));
          var price   = prices[ticker];
          if (!price || price <= 0) return;

          var chg     = dayOpen > 0 ? price - dayOpen : 0;
          var chgPct  = dayOpen > 0 ? (chg / dayOpen * 100) : 0;
          var color   = chg >= 0 ? '#2EBD85' : '#F6465D';
          var sign    = chg >= 0 ? '+' : '-';

          var priceEl = row.querySelector('.stock-price');
          if (priceEl) priceEl.textContent = '$' + fmt2(price);

          var changeEl = row.querySelector('.stock-change');
          if (changeEl && dayOpen > 0) {
            changeEl.style.color = color;
            var absEl = changeEl.querySelector('.chg-abs');
            var pctEl = changeEl.querySelector('.chg-pct');
            if (absEl) absEl.textContent = sign + fmt2(chg);
            if (pctEl) pctEl.textContent = '(' + sign + fmt2(chgPct) + '%)';
          }
        });
      };
      xhr.send();
    }

    refresh();
    _timer = setInterval(refresh, 4000);
  }

  document.addEventListener('DOMContentLoaded', startPolling);
  document.addEventListener('turbo:load', startPolling);
})();
</script>
