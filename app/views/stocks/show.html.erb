<% content_for :title, "#{@stock.ticker} — #{@stock.company_name}" %>

<%# ── Info bar (fixed below navbar) ── %>
<div style="position: fixed; top: 64px; left: 0; right: 0; z-index: 98;
            background: rgba(13,15,23,0.97); backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255,255,255,0.07);
            height: 56px; display: flex; align-items: center; padding: 0 1.5rem; gap: 1.5rem;">

  <%= link_to "← Markets", stocks_path,
      style: "color: #929AA5; font-size: 0.78rem; text-decoration: none; flex-shrink: 0; transition: color 0.2s;",
      onmouseover: "this.style.color='#EAECEF'", onmouseout: "this.style.color='#929AA5'" %>

  <div style="width: 1px; height: 20px; background: rgba(255,255,255,0.1); flex-shrink: 0;"></div>

  <div style="width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0;
              background: rgba(20,184,166,0.1); border: 1px solid rgba(20,184,166,0.2);
              display: flex; align-items: center; justify-content: center; overflow: hidden;">
    <img src="<%= stock_logo_url(@stock.ticker) %>"
         alt="<%= @stock.ticker %>"
         style="width: 20px; height: 20px; object-fit: contain;"
         onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
    <span style="display: none; width: 100%; height: 100%; align-items: center;
                 justify-content: center; font-size: 0.55rem; font-weight: 700; color: #14B8A6;">
      <%= @stock.ticker.first(2).upcase %>
    </span>
  </div>

  <div style="display: flex; align-items: baseline; gap: 0.5rem; flex-shrink: 0;">
    <span class="tw-font-custom" style="color: #EAECEF; font-size: 1rem; letter-spacing: 0.08em;">
      <%= @stock.ticker %>
    </span>
    <span style="color: #929AA5; font-size: 0.78rem;"><%= @stock.company_name %></span>
  </div>

  <div style="width: 1px; height: 20px; background: rgba(255,255,255,0.1); flex-shrink: 0;"></div>

  <div style="display: flex; align-items: baseline; gap: 0.5rem; flex-shrink: 0;">
    <span id="live-price" style="color: #EAECEF; font-size: 1.1rem; font-weight: 700;">
      <% if @stock.last_price %>
        $<%= format("%.2f", @stock.last_price.to_f) %>
      <% else %>
        —
      <% end %>
    </span>
    <span id="price-change" style="font-size: 0.78rem; font-weight: 600;"></span>
    <span style="color: #929AA5; font-size: 0.7rem;">USD</span>
  </div>

  <div style="margin-left: auto; display: flex; align-items: center; gap: 1.25rem; flex-shrink: 0;">
    <span style="display: flex; align-items: center; gap: 0.35rem; font-size: 0.75rem; color: #929AA5;">
      <span style="width: 8px; height: 8px; border-radius: 2px; background: #2EBD85; display: inline-block;"></span>
      Bullish
    </span>
    <span style="display: flex; align-items: center; gap: 0.35rem; font-size: 0.75rem; color: #929AA5;">
      <span style="width: 8px; height: 8px; border-radius: 2px; background: #F6465D; display: inline-block;"></span>
      Bearish
    </span>
    <span style="background: rgba(20,184,166,0.12); color: #14B8A6; font-size: 0.68rem;
                 font-weight: 700; padding: 0.12rem 0.5rem; border-radius: 20px; letter-spacing: 0.05em;">● LIVE</span>
    <span style="color: #929AA5; font-size: 0.68rem; opacity: 0.5;">Simulated · 1min K</span>
  </div>

</div>

<%# ── Full-screen chart (fills everything below info bar) ── %>
<div id="chart-container"
     style="position: fixed; top: 120px; left: 0; right: 0; bottom: 0; z-index: 1;"></div>

<%# ── Buy / Sell floating buttons ── %>
<% if true %>
  <div style="position: fixed; bottom: 1.75rem; right: 1.75rem; z-index: 9999;
              display: flex; flex-direction: column; gap: 0.6rem; pointer-events: auto;">
    <button onclick="openTradeModal('buy')"
            style="background: #2EBD85; color: #fff; font-weight: 700; font-size: 0.95rem;
                   border: none; border-radius: 8px; padding: 0.7rem 1.8rem; cursor: pointer;
                   box-shadow: 0 4px 20px rgba(46,189,133,0.35); transition: background 0.2s;"
            onmouseover="this.style.background='#25a673'" onmouseout="this.style.background='#2EBD85'">
      ▲ Buy
    </button>
    <button onclick="openTradeModal('sell')"
            style="background: #F6465D; color: #fff; font-weight: 700; font-size: 0.95rem;
                   border: none; border-radius: 8px; padding: 0.7rem 1.8rem; cursor: pointer;
                   box-shadow: 0 4px 20px rgba(246,70,93,0.35); transition: background 0.2s;"
            onmouseover="this.style.background='#d93650'" onmouseout="this.style.background='#F6465D'">
      ▼ Sell
    </button>
  </div>
<% end %>

<%# ── Trade Modal ── %>
<% if true %>
<div id="trade-modal"
     style="display: none; position: fixed; inset: 0; z-index: 200;
            background: rgba(0,0,0,0.75); align-items: center; justify-content: center; padding: 1.5rem;"
     onclick="if(event.target===this) closeTrade()">
  <div style="background: #12141e; border: 1px solid rgba(255,255,255,0.1);
              border-radius: 16px; padding: 2rem; width: 100%; max-width: 400px; position: relative;">

    <button onclick="closeTrade()"
            style="position: absolute; top: 1rem; right: 1rem; background: none; border: none;
                   color: #929AA5; font-size: 1.4rem; cursor: pointer; line-height: 1; padding: 0;"
            onmouseover="this.style.color='#EAECEF'" onmouseout="this.style.color='#929AA5'">&times;</button>

    <h2 id="trade-title" class="tw-font-custom"
        style="color: #EAECEF; font-size: 1.2rem; letter-spacing: 0.08em;
               text-transform: uppercase; margin: 0 0 1.5rem;"></h2>

    <div id="trade-msg" style="display: none; border-radius: 8px; padding: 0.7rem 1rem;
                               margin-bottom: 1rem; font-size: 0.85rem; text-align: center;"></div>

    <%= form_with url: "#", id: "trade-form", local: true do |f| %>
      <input type="hidden" name="trade[ticker]" value="<%= @stock.ticker %>">
      <input type="hidden" id="trade-action-field" name="trade[action]" value="buy">

      <div style="margin-bottom: 1.1rem;">
        <label style="display: block; color: #929AA5; font-size: 0.72rem; font-weight: 700;
                      text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.4rem;">
          Portfolio
        </label>
        <% if @portfolios.any? %>
          <select id="trade-portfolio-select" name="portfolio_id"
                  class="bnb-input" style="cursor: pointer;">
            <% @portfolios.each do |p| %>
              <option value="<%= p.id %>"><%= p.league.name %> — $<%= number_with_precision(p.cash_balance, precision: 2, delimiter: ",") %> cash</option>
            <% end %>
          </select>
        <% else %>
          <div id="no-portfolio-msg"
               style="background: rgba(246,70,93,0.1); border: 1px solid rgba(246,70,93,0.25);
                      border-radius: 8px; padding: 0.75rem 1rem; font-size: 0.82rem; color: #F6465D;">
            You have no portfolios. <%= link_to "Join a league", leagues_path,
                style: "color: #14B8A6; text-decoration: underline;" %> first.
          </div>
          <select id="trade-portfolio-select" name="portfolio_id" style="display: none;"></select>
        <% end %>
      </div>

      <div style="margin-bottom: 1.1rem;">
        <label style="display: block; color: #929AA5; font-size: 0.72rem; font-weight: 700;
                      text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.4rem;">
          Price (USD)
        </label>
        <input type="number" id="trade-price-field" name="trade[price]"
               step="0.01" min="0.01" required class="bnb-input"
               style="font-weight: 700; color: #14B8A6;">
      </div>

      <div style="margin-bottom: 1.5rem;">
        <label style="display: block; color: #929AA5; font-size: 0.72rem; font-weight: 700;
                      text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.4rem;">
          Quantity (shares)
        </label>
        <input type="number" id="trade-qty-field" name="trade[quantity]"
               step="1" min="1" required class="bnb-input">
      </div>

      <div id="trade-cost-preview"
           style="background: rgba(255,255,255,0.04); border-radius: 8px; padding: 0.75rem 1rem;
                  margin-bottom: 1.25rem; font-size: 0.82rem; color: #929AA5; display: none;">
        Total: <span id="trade-total" style="color: #EAECEF; font-weight: 700;"></span>
      </div>

      <% if @portfolios.any? %>
      <button id="trade-submit-btn" type="submit"
              style="width: 100%; padding: 0.85rem; font-size: 0.95rem; font-weight: 700;
                     border: none; border-radius: 6px; cursor: pointer; transition: background 0.2s;">
        Confirm
      </button>
      <% end %>
    <% end %>

  </div>
</div>

<script>
  const TRADE_COLORS = { buy: '#2EBD85', sell: '#F6465D' };

  function openTradeModal(action) {
    const modal  = document.getElementById('trade-modal');
    const title  = document.getElementById('trade-title');
    const btn    = document.getElementById('trade-submit-btn');
    const af     = document.getElementById('trade-action-field');
    const priceF = document.getElementById('trade-price-field');
    const msg    = document.getElementById('trade-msg');

    af.value          = action;
    title.textContent = action === 'buy' ? '▲ Buy <%= @stock.ticker %>' : '▼ Sell <%= @stock.ticker %>';
    if (btn) {
      btn.style.background = TRADE_COLORS[action];
      btn.textContent   = action === 'buy' ? 'Confirm Buy' : 'Confirm Sell';
    }
    msg.style.display = 'none';

    const livePrice = document.getElementById('live-price');
    if (livePrice) {
      const raw = livePrice.textContent.replace('$', '').replace(',', '');
      if (!isNaN(parseFloat(raw))) priceF.value = parseFloat(raw).toFixed(2);
    }

    modal.style.display = 'flex';
  }

  function closeTrade() {
    document.getElementById('trade-modal').style.display = 'none';
  }

  document.addEventListener('DOMContentLoaded', function () {
    const priceF = document.getElementById('trade-price-field');
    const qtyF   = document.getElementById('trade-qty-field');
    const total  = document.getElementById('trade-total');
    const preview = document.getElementById('trade-cost-preview');

    function updateTotal() {
      const p = parseFloat(priceF?.value) || 0;
      const q = parseInt(qtyF?.value) || 0;
      if (p > 0 && q > 0) {
        total.textContent = '$' + (p * q).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        preview.style.display = 'block';
      } else {
        preview.style.display = 'none';
      }
    }

    priceF?.addEventListener('input', updateTotal);
    qtyF?.addEventListener('input', updateTotal);

    const sel = document.getElementById('trade-portfolio-select');
    const form = document.getElementById('trade-form');

    function syncFormAction() {
      if (sel && form && sel.value) {
        form.action = '/portfolios/' + sel.value + '/trades';
      }
    }

    sel?.addEventListener('change', syncFormAction);
    syncFormAction();

    form?.addEventListener('submit', function (e) {
      const portfolioId = sel?.value;
      if (!portfolioId) {
        e.preventDefault();
        const msg = document.getElementById('trade-msg');
        msg.textContent = 'Please join a league first to trade.';
        msg.style.background = 'rgba(246,70,93,0.12)';
        msg.style.color = '#F6465D';
        msg.style.display = 'block';
        return;
      }
      this.action = '/portfolios/' + portfolioId + '/trades';
    });
  });
</script>
<% end %>

<script src="https://unpkg.com/lightweight-charts@4.2.0/dist/lightweight-charts.standalone.production.js"></script>

<script>
(function () {
  const historicalData  = <%= raw @chart_data %>;
  const INITIAL_COUNT   = 50;
  const STEPS           = 60;
  const TICK_MS         = 1000;
  const CANDLE_GAP_MS   = 0;
  const CANDLE_TOTAL_MS = (STEPS * TICK_MS) + CANDLE_GAP_MS;

  const serverStartTime = <%= Rails.application.config.server_start_time.to_i * 1000 %>;

  const livePriceEl  = document.getElementById('live-price');
  const priceChgEl   = document.getElementById('price-change');

  function updatePriceDisplay(currentClose, openPrice) {
    if (!livePriceEl) return;
    livePriceEl.textContent = '$' + currentClose.toFixed(2);
    if (priceChgEl && openPrice) {
      const chg    = currentClose - openPrice;
      const chgPct = (chg / openPrice) * 100;
      const sign   = chg >= 0 ? '+' : '';
      priceChgEl.textContent    = sign + chg.toFixed(2) + ' (' + sign + chgPct.toFixed(2) + '%)';
      priceChgEl.style.color    = chg >= 0 ? '#2EBD85' : '#F6465D';
    }
  }

  function initChart() {
    const container = document.getElementById('chart-container');
    if (!container || typeof LightweightCharts === 'undefined') return;

    if (container._lwcChart) {
      try { container._lwcChart.remove(); } catch (_) {}
    }

    const chart = LightweightCharts.createChart(container, {
      layout: {
        background: { color: '#0d0f17' },
        textColor: '#929AA5',
        fontFamily: "'Inter', 'Segoe UI', sans-serif",
      },
      grid: {
        vertLines: { color: 'rgba(255,255,255,0.04)' },
        horzLines: { color: 'rgba(255,255,255,0.04)' },
      },
      crosshair: {
        mode: LightweightCharts.CrosshairMode.Normal,
        vertLine: { color: 'rgba(20,184,166,0.4)', labelBackgroundColor: '#14B8A6' },
        horzLine: { color: 'rgba(20,184,166,0.4)', labelBackgroundColor: '#14B8A6' },
      },
      rightPriceScale: {
        borderColor: 'rgba(255,255,255,0.08)',
        scaleMargins: { top: 0.06, bottom: 0.06 },
      },
      timeScale: {
        borderColor: 'rgba(255,255,255,0.08)',
        timeVisible: true,
        secondsVisible: false,
      },
      width:  container.clientWidth,
      height: container.clientHeight,
    });

    container._lwcChart = chart;

    const candleSeries = chart.addCandlestickSeries({
      upColor:        '#2EBD85',
      downColor:      '#F6465D',
      borderVisible:  false,
      wickUpColor:    '#2EBD85',
      wickDownColor:  '#F6465D',
    });

    const elapsed    = Date.now() - serverStartTime;
    const skipCount  = Math.floor(elapsed / CANDLE_TOTAL_MS);
    const startIndex = Math.min(INITIAL_COUNT + skipCount, historicalData.length - 1);

    candleSeries.setData(historicalData.slice(0, startIndex));
    chart.timeScale().fitContent();

    if (startIndex > 0) {
      const lastCandle = historicalData[startIndex - 1];
      updatePriceDisplay(lastCandle.close, lastCandle.open);
    }

   function generateTicks(candle, steps) {
  const { open, high, low, close } = candle;
  const range = high - low || 0.01;

  const p1 = Math.floor(steps * 0.3);
  const p2 = Math.floor(steps * 0.4);
  const p3 = steps - p1 - p2; // 確保三段加起來 = steps

  const hitHighFirst = Math.random() > 0.5;
  const basePath = [];

  if (hitHighFirst) {
    for (let i = 1; i <= p1; i++)
      basePath.push(open + (high - open) * (i / p1));
    for (let i = 1; i <= p2; i++)
      basePath.push(high + (low - high) * (i / p2));
    for (let i = 1; i <= p3; i++)
      basePath.push(low + (close - low) * (i / p3));
  } else {
    for (let i = 1; i <= p1; i++)
      basePath.push(open + (low - open) * (i / p1));
    for (let i = 1; i <= p2; i++)
      basePath.push(low + (high - low) * (i / p2));
    for (let i = 1; i <= p3; i++)
      basePath.push(high + (close - high) * (i / p3));
  }

  const ticks = [open];

  for (let i = 0; i < basePath.length; i++) {
    const isLast = i === basePath.length - 1;

    // 最後一個 tick 不加 shock，保證結尾是 close
    if (!isLast && Math.random() < 0.05) {
      const shockSize = range * (0.05 + Math.random() * 0.1); // 縮小 shock 幅度避免卡邊
      const direction = Math.random() < 0.5 ? 1 : -1;
      const shockedPrice = basePath[i] + direction * shockSize;
      ticks.push(Math.min(high, Math.max(low, shockedPrice)));
    } else {
      ticks.push(basePath[i]);
    }
  }

  return ticks;
}

    function playCandle(index, onDone) {
      if (index >= historicalData.length) return;
      const candle = historicalData[index];
      const ticks  = generateTicks(candle, STEPS);
      let tickIndex = 0;
      const tickInterval = setInterval(() => {
        const currentClose = ticks[tickIndex];
        candleSeries.update({
          time:  candle.time,
          open:  candle.open,
          high:  Math.max(candle.open, currentClose),
          low:   Math.min(candle.open, currentClose),
          close: currentClose,
        });
        updatePriceDisplay(currentClose, candle.open);
        tickIndex++;
        if (tickIndex >= ticks.length) {
          clearInterval(tickInterval);
          candleSeries.update(candle);
          setTimeout(onDone, CANDLE_GAP_MS);
        }
      }, TICK_MS);
    }

    let currentIndex = startIndex;
    function playNext() {
      if (currentIndex >= historicalData.length) return;
      playCandle(currentIndex, () => {
        currentIndex++;
        playNext();
      });
    }
    playNext();

    window.addEventListener('resize', () => {
      chart.applyOptions({
        width:  container.clientWidth,
        height: container.clientHeight,
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initChart);
  } else {
    initChart();
  }
  document.addEventListener('turbo:load', initChart);
})();
</script>
