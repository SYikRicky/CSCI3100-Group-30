<div class="tw-font-custom tw-w-[480px] tw-h-[350px]  tw-mt-[140px] tw-pt-8 tw-rounded-2xl tw-ml-[360px] tw-bg-white/5 tw-backdrop-blur-xl tw-border-t tw-border-white/20 tw-shadow-[0_-20px_60px_-15px_rgba(255,255,255,0.1)] tw-text-white tw-text-center">
  <h1 class="tw-text-5xl tw-font-custom tw-mt-6 tw-mb-6 tw-tracking-widest tw-uppercase tw-text-white">
    Mock Fund League
  </h1>
  
  <p class="tw-text-lg tw-text-white/70 tw-mb-10 tw-font-light">
    Compete with friends in virtual stock trading leagues.
  </p>

  <div class="tw-flex tw-flex-col tw-items-center tw-gap-6">
    <% if user_signed_in? %>
      <div class="tw-text-white">
        Welcome back, <span class="tw-font-bold tw-text-blue-400"><%= current_user.display_name %></span>!
      </div>
      
      <div class="tw-flex tw-items-center tw-gap-4">
        <%= link_to "My Leagues", leagues_path, 
            class: "tw-px-8 tw-py-3 tw-bg-blue-600 tw-text-white tw-rounded-lg hover:tw-bg-blue-500 tw-transition-all tw-shadow-lg" %>
        
        <%= link_to "Sign Out", destroy_user_session_path, 
            data: { turbo_method: :delete }, 
            class: "tw-text-sm tw-text-white/40 hover:tw-text-white/80 tw-underline tw-decoration-dotted" %>
      </div>

    <% else %>
      <div class="tw-flex tw-gap-4">
        <%= link_to "Sign In", new_user_session_path, 
            class: "tw-px-6 tw-py-2 tw-border tw-border-white/30 tw-text-white tw-rounded-lg hover:tw-bg-white/10 tw-transition" %>
            
        <%= link_to "Sign Up", new_user_registration_path, 
            class: "tw-px-6 tw-py-2 tw-bg-white tw-text-black tw-rounded-lg hover:tw-bg-gray-200 tw-transition tw-font-bold" %>
      </div>
    <% end %>
  </div>

 <div class="tw-group tw-mt-10 -tw-ml-2 tw-h-12 tw-w-100 tw-bg-transparent [perspective:1000px]">
  
  <div class="tw-relative tw-h-full tw-w-full tw-transition-transform tw-duration-700 [transform-style:preserve-3d] group-hover:[transform:rotateY(180deg)]">
    
    <div class="tw-absolute tw-inset-0 tw-flex tw-items-center tw-justify-center tw-gap-3 tw-bg-transparent tw-text-white tw-text-[24px] tw-font-medium [backface-visibility:hidden]">
      <span class="tw-text-yellow-400">★</span>
      <span>Real competition</span>
      <span class="tw-text-yellow-400">★</span>
    </div>

    <div class="tw-absolute tw-inset-0 tw-flex tw-items-center tw-justify-center tw-gap-3 tw-bg-transparent tw-text-white tw-text-[24px] [backface-visibility:hidden] [transform:rotateY(180deg)]">
      <span class="tw-text-yellow-400">★</span>
      <span>Join leagues</span>
      <span class="tw-text-yellow-400">★</span>
    </div>

    </div>
  </div>

  <div class="tw-group tw-mt-6 -tw-ml-2 tw-h-12 tw-w-120 tw-bg-transparent [perspective:1000px]">
  
  <div class="tw-relative tw-h-full tw-w-full tw-transition-transform tw-duration-700 [transform-style:preserve-3d] group-hover:[transform:rotateY(180deg)]">
    
    <div class="tw-absolute tw-inset-0 tw-flex tw-items-center tw-justify-center tw-gap-3 tw-bg-transparent tw-text-white  tw-text-[24px] [backface-visibility:hidden]">
      <span class="tw-text-yellow-400">★</span>
      <span>Various assets</span>
      <span class="tw-text-yellow-400">★</span>
    </div>

    <div class="tw-absolute tw-inset-0 tw-flex tw-items-center tw-justify-center tw-gap-3 tw-bg-transparent tw-text-white tw-text-[24px] [backface-visibility:hidden] [transform:rotateY(180deg)]">
      <span class="tw-text-yellow-400">★</span>
      <span>UP to 30 stocks</span>
      <span class="tw-text-yellow-400">★</span>
    </div>

  </div>
</div>

</div>