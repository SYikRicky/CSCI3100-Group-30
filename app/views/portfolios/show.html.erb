<div style="display: grid; grid-template-columns: 1fr 280px; gap: 1.5rem; padding: 1.25rem 1.5rem;">
  <div>
    <h1>Portfolio</h1>

    <p><strong>League:</strong> <%= @portfolio.league.name %></p>
    <p><strong>Cash balance:</strong> <%= number_with_precision(@portfolio.cash_balance, precision: 2) %></p>
    <p><strong>Total value:</strong> <%= number_with_precision(@portfolio.total_value, precision: 2) %></p>

    <h2>Virtual Trading Only</h2>

    <%= form_with url: portfolio_trades_path(@portfolio), method: :post, local: true do |f| %>
      <div>
        <%= label_tag "trade_ticker", "Ticker" %>
        <%= text_field_tag "trade[ticker]", nil, id: "trade_ticker", required: true %>
      </div>

      <div>
        <%= label_tag "trade_action", "Action" %>
        <%= select_tag "trade[action]", options_for_select([["Buy", "buy"], ["Sell", "sell"]]), id: "trade_action" %>
      </div>

      <div>
        <%= label_tag "trade_quantity", "Quantity" %>
        <%= number_field_tag "trade[quantity]", nil, id: "trade_quantity", step: "1", min: "1", required: true %>
      </div>

      <div>
        <%= label_tag "trade_price", "Price" %>
        <%= number_field_tag "trade[price]", nil, id: "trade_price", step: "0.01", min: "0.01", required: true %>
      </div>

      <div>
        <%= f.submit "Execute Trade" %>
      </div>
    <% end %>

    <h2>Holdings</h2>
    <% if @holdings.any? %>
      <table>
        <thead>
          <tr>
            <th>Ticker</th>
            <th>Quantity</th>
            <th>Average cost</th>
            <th>Market value</th>
          </tr>
        </thead>
        <tbody>
          <% @holdings.each do |holding| %>
            <tr>
              <td><%= holding.stock.ticker %></td>
              <td><%= holding.quantity %></td>
              <td><%= number_with_precision(holding.average_cost, precision: 2) %></td>
              <td><%= number_with_precision(holding.market_value, precision: 2) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p>No holdings yet.</p>
    <% end %>
  </div>

  <aside style="border-left: 1px solid #e5e7eb; padding-left: 1rem;">
    <h3 style="margin-top: 0;">Portfolio Sidebar</h3>
    <p style="font-size: 0.9rem;"><strong>Virtual Trading Only</strong></p>
    <p style="font-size: 0.9rem;">Trades in this league use simulated money and simulated holdings.</p>
    <p style="font-size: 0.9rem;">Cash: <%= number_with_precision(@portfolio.cash_balance, precision: 2) %></p>
    <p style="font-size: 0.9rem;">Holdings value: <%= number_with_precision(@portfolio.holdings_value, precision: 2) %></p>
  </aside>
</div>
