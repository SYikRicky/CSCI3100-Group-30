<% content_for :title, "New League" %>

<div style="max-width: 680px; margin: 0 auto; padding: 2.5rem 1.5rem;">
  <div style="margin-bottom: 0.75rem;">
    <%= link_to "← Back to Leagues", leagues_path,
        style: "color: #929AA5; text-decoration: none; font-size: 0.82rem;",
        onmouseover: "this.style.color='#EAECEF'", onmouseout: "this.style.color='#929AA5'" %>
  </div>
  <h1 class="tw-font-custom" style="color: #EAECEF; font-size: 1.75rem; letter-spacing: 0.1em;
              text-transform: uppercase; margin: 0 0 1.75rem;">New League</h1>

  <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
              border-radius: 12px; padding: 2rem;">
    <%= render "form", league: @league %>
  </div>
</div>
