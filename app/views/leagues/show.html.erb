<%# ── Main content area ── %>
<div style="padding: 2rem 1.5rem; padding-right: 3rem">
  <h1 style="font-size: 1.5rem; font-weight: 700; color: #111827; margin: 0 0 0.25rem">
    <%= @league.name %>
  </h1>
  <p style="color: #6b7280; font-size: 0.9rem; margin: 0">
    <%= @league.description.presence || "No description." %>
  </p>

  <% if (portfolio = current_user.portfolios.find_by(league: @league)) %>
    <div style="margin-top: 0.75rem">
      <%= link_to "View My Portfolio", portfolio_path(portfolio) %>
    </div>
  <% end %>
</div>

<%# ── Right sidebar ── %>
<div data-controller="league-sidebar"
     style="position: fixed; right: 0; top: 60px; height: calc(100vh - 60px);
            display: flex; align-items: flex-start; z-index: 20">

  <%# ── Panel 0: Members ── %>
  <div data-league-sidebar-target="panel"
       data-testid="sidebar-panel-members"
       data-open="false"
       style="width: 0; overflow: hidden; transition: width 0.25s ease;
              height: 100%; background: white;
              border-left: 1px solid #e5e7eb;
              box-shadow: -2px 0 8px rgba(0,0,0,0.08)">
    <div style="width: 280px; padding: 1rem; box-sizing: border-box; overflow-y: auto; height: 100%">

      <h3 style="margin: 0 0 0.75rem; font-size: 0.95rem; font-weight: 600; color: #111827">Members</h3>

      <%# Owner row %>
      <div style="display: flex; align-items: center; gap: 0.5rem; padding: 0.4rem 0; border-bottom: 1px solid #f3f4f6">
        <div style="width: 28px; height: 28px; background: #4f46e5; border-radius: 50%;
                    display: flex; align-items: center; justify-content: center;
                    color: white; font-size: 0.75rem; font-weight: 600; flex-shrink: 0">
          <%= @league.owner.display_name.first.upcase %>
        </div>
        <div>
          <div style="font-size: 0.8rem; font-weight: 500"><%= @league.owner.display_name %></div>
          <div style="font-size: 0.72rem; color: #6b7280"><%= @league.owner.email %></div>
        </div>
        <span style="margin-left: auto; font-size: 0.7rem; color: #4f46e5; font-weight: 600">Owner</span>
      </div>

      <%# Other members %>
      <% other_members = @members.reject { |m| m.user_id == @league.owner_id } %>
      <% other_members.each do |membership| %>
        <div style="display: flex; align-items: center; gap: 0.5rem; padding: 0.4rem 0; border-bottom: 1px solid #f3f4f6">
          <div style="width: 28px; height: 28px; background: #e5e7eb; border-radius: 50%;
                      display: flex; align-items: center; justify-content: center;
                      font-size: 0.75rem; font-weight: 600; flex-shrink: 0">
            <%= membership.user.display_name.first.upcase %>
          </div>
          <div>
            <div style="font-size: 0.8rem; font-weight: 500"><%= membership.user.display_name %></div>
            <div style="font-size: 0.72rem; color: #6b7280"><%= membership.user.email %></div>
          </div>
        </div>
      <% end %>

      <%# Invite form (owner only) %>
      <% if current_user == @league.owner %>
        <div style="margin-top: 1rem; padding-top: 0.75rem; border-top: 1px solid #e5e7eb">
          <p style="font-size: 0.8rem; font-weight: 600; color: #374151; margin: 0 0 0.4rem">Invite a member</p>
          <%= form_with url: invite_league_path(@league), method: :post, style: "display: flex; gap: 0.4rem" do |f| %>
            <%= f.text_field :identifier,
                  placeholder: "Email or display name",
                  style: "flex: 1; font-size: 0.8rem; padding: 0.35rem 0.5rem;
                          border: 1px solid #d1d5db; border-radius: 4px" %>
            <%= f.submit "Invite",
                  style: "font-size: 0.8rem; padding: 0.35rem 0.6rem; background: #4f46e5;
                          color: white; border: none; border-radius: 4px; cursor: pointer" %>
          <% end %>
        </div>
      <% end %>

    </div>
  </div>

  <%# ── Panel 1: Details ── %>
  <div data-league-sidebar-target="panel"
       data-testid="sidebar-panel-details"
       data-open="false"
       style="width: 0; overflow: hidden; transition: width 0.25s ease;
              height: 100%; background: white;
              border-left: 1px solid #e5e7eb;
              box-shadow: -2px 0 8px rgba(0,0,0,0.08)">
    <div style="width: 280px; padding: 1rem; box-sizing: border-box; overflow-y: auto; height: 100%">

      <h3 style="margin: 0 0 0.75rem; font-size: 0.95rem; font-weight: 600; color: #111827">Details</h3>

      <dl style="font-size: 0.82rem; margin: 0; display: grid; grid-template-columns: auto 1fr; gap: 0.3rem 0.6rem">
        <dt style="font-weight: 600; color: #374151">Name</dt>
        <dd style="margin: 0; color: #111827"><%= @league.name %></dd>

        <dt style="font-weight: 600; color: #374151">Description</dt>
        <dd style="margin: 0; color: #111827"><%= @league.description.presence || "—" %></dd>

        <dt style="font-weight: 600; color: #374151">Capital</dt>
        <dd style="margin: 0; color: #111827"><%= number_with_delimiter(@league.starting_capital.to_i) %></dd>

        <dt style="font-weight: 600; color: #374151">Starts</dt>
        <dd style="margin: 0; color: #111827"><%= @league.starts_at.strftime("%Y-%m-%d %H:%M") %></dd>

        <dt style="font-weight: 600; color: #374151">Ends</dt>
        <dd style="margin: 0; color: #111827"><%= @league.ends_at.strftime("%Y-%m-%d %H:%M") %></dd>

        <dt style="font-weight: 600; color: #374151">Status</dt>
        <dd style="margin: 0; color: #111827"><%= @league.status.capitalize %></dd>

        <% if current_user == @league.owner %>
          <dt style="font-weight: 600; color: #374151">Invite code</dt>
          <dd style="margin: 0; color: #111827; font-family: monospace"><%= @league.invite_code %></dd>
        <% end %>
      </dl>

      <% if current_user == @league.owner %>
        <div style="margin-top: 1.25rem; padding-top: 0.75rem; border-top: 1px solid #e5e7eb">
          <%= button_to "Destroy League", @league, method: :delete,
                data: { turbo_confirm: "Are you sure? This cannot be undone." },
                style: "width: 100%; padding: 0.4rem; background: #ef4444; color: white;
                        border: none; border-radius: 4px; cursor: pointer; font-size: 0.82rem" %>
        </div>
      <% end %>

    </div>
  </div>

  <%# ── Tab buttons (always visible on right edge) ── %>
  <div style="display: flex; flex-direction: column; height: 100%">

    <button type="button"
            data-testid="sidebar-tab-members"
            data-action="click->league-sidebar#toggle"
            data-league-sidebar-index-param="0"
            style="writing-mode: vertical-rl; transform: rotate(180deg);
                   padding: 1.25rem 0.6rem; background: #4f46e5; color: white;
                   border: none; border-bottom: 1px solid rgba(255,255,255,0.2);
                   cursor: pointer; font-size: 0.82rem; font-weight: 600;
                   letter-spacing: 0.05em">
      Members
    </button>

    <button type="button"
            data-testid="sidebar-tab-details"
            data-action="click->league-sidebar#toggle"
            data-league-sidebar-index-param="1"
            style="writing-mode: vertical-rl; transform: rotate(180deg);
                   padding: 1.25rem 0.6rem; background: #6366f1; color: white;
                   border: none; cursor: pointer; font-size: 0.82rem; font-weight: 600;
                   letter-spacing: 0.05em">
      Details
    </button>

  </div>
</div>
