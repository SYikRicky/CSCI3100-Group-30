<%# ── Main content area ── %>
<div style="max-width: 1280px; margin: 0 auto; padding: 2.5rem 1.5rem; padding-right: calc(1.5rem + 44px);">
  <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
    <%= link_to "← Leagues", leagues_path,
        style: "color: #929AA5; text-decoration: none; font-size: 0.8rem; transition: color 0.2s;",
        onmouseover: "this.style.color='#EAECEF'", onmouseout: "this.style.color='#929AA5'" %>
  </div>
  <h1 style="font-size: 1.75rem; font-weight: 700; color: #EAECEF; margin: 0 0 0.3rem;">
    <%= @league.name %>
  </h1>
  <p style="color: #929AA5; font-size: 0.875rem; margin: 0;">
    <%= @league.description.presence || "No description." %>
  </p>


  <%# ── Leaderboard ── %>
  <% if @leaderboard.any? %>
    <div style="margin-top: 2rem; background: #12141e; border: 1px solid rgba(255,255,255,0.07);
                border-radius: 12px; overflow: hidden;">
      <div style="padding: 1rem 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.07);
                  display: flex; align-items: center; justify-content: space-between;">
        <h2 style="color: #EAECEF; font-size: 0.9rem; font-weight: 700; margin: 0;
                   text-transform: uppercase; letter-spacing: 0.08em;">Leaderboard</h2>
        <span style="color: #929AA5; font-size: 0.72rem;">
          Starting capital: $<%= number_with_delimiter(@league.starting_capital.to_i) %>
        </span>
      </div>
      <table style="width: 100%; border-collapse: collapse;">
        <thead>
          <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
            <th style="padding: 0.65rem 1.5rem; text-align: left; color: #929AA5; font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; width: 40px;">#</th>
            <th style="padding: 0.65rem 1rem; text-align: left; color: #929AA5; font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;">Name</th>
            <th style="padding: 0.65rem 1rem; text-align: right; color: #929AA5; font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;">Total Value</th>
            <th style="padding: 0.65rem 1.5rem; text-align: right; color: #929AA5; font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;">P&amp;L</th>
          </tr>
        </thead>
        <tbody>
          <% @leaderboard.each_with_index do |entry, i| %>
            <% is_me = entry[:user].id == current_user.id %>
            <tr style="border-bottom: 1px solid rgba(255,255,255,0.04);
                       <%= is_me ? 'background: rgba(20,184,166,0.06);' : '' %>"
                onmouseover="this.style.background='<%= is_me ? 'rgba(20,184,166,0.1)' : 'rgba(255,255,255,0.02)' %>'"
                onmouseout="this.style.background='<%= is_me ? 'rgba(20,184,166,0.06)' : 'transparent' %>'">
              <td style="padding: 0.85rem 1.5rem; color: #929AA5; font-size: 0.82rem; font-weight: 700;">
                <% if i == 0 %>🥇<% elsif i == 1 %>🥈<% elsif i == 2 %>🥉<% else %><%= i + 1 %><% end %>
              </td>
              <td style="padding: 0.85rem 1rem;">
                <%= link_to portfolio_path(entry[:portfolio]),
                    style: "display: flex; align-items: center; gap: 0.5rem; text-decoration: none;",
                    onmouseover: "this.querySelector('.lb-name').style.color='#14B8A6'",
                    onmouseout:  "this.querySelector('.lb-name').style.color='#{is_me ? '#14B8A6' : '#EAECEF'}'" do %>
                  <div style="width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0;
                              background: <%= is_me ? 'rgba(20,184,166,0.2)' : 'rgba(99,102,241,0.2)' %>;
                              border: 1px solid <%= is_me ? 'rgba(20,184,166,0.4)' : 'rgba(99,102,241,0.3)' %>;
                              display: flex; align-items: center; justify-content: center;
                              color: <%= is_me ? '#14B8A6' : '#818cf8' %>; font-size: 0.7rem; font-weight: 700;">
                    <%= entry[:user].display_name.first.upcase %>
                  </div>
                  <div>
                    <div class="lb-name" style="color: <%= is_me ? '#14B8A6' : '#EAECEF' %>; font-size: 0.85rem; font-weight: <%= is_me ? '700' : '500' %>; transition: color 0.15s;">
                      <%= entry[:user].display_name %><% if is_me %> <span style="font-size: 0.68rem; opacity: 0.8;">(you)</span><% end %>
                    </div>
                  </div>
                <% end %>
              </td>
              <td style="padding: 0.85rem 1rem; text-align: right; color: #EAECEF; font-size: 0.88rem; font-weight: 700;">
                $<%= number_with_precision(entry[:total_value], precision: 2, delimiter: ",") %>
              </td>
              <td style="padding: 0.85rem 1.5rem; text-align: right;">
                <% color = entry[:pnl] >= 0 ? '#2EBD85' : '#F6465D' %>
                <% sign  = entry[:pnl] >= 0 ? '+' : '' %>
                <div style="color: <%= color %>; font-size: 0.85rem; font-weight: 700;">
                  <%= sign %>$<%= number_with_precision(entry[:pnl].abs, precision: 2, delimiter: ",") %>
                  <%= entry[:pnl] < 0 ? '-' : '' %>
                </div>
                <div style="color: <%= color %>; font-size: 0.72rem; opacity: 0.85;">
                  (<%= sign %><%= number_with_precision(entry[:pnl_pct].abs, precision: 2) %>%)
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

</div>

<%# ── Right sidebar ── %>
<div data-controller="league-sidebar"
     style="position: fixed; right: 0; top: 64px; height: calc(100vh - 64px);
            display: flex; align-items: flex-start; z-index: 20;">

  <%# ── Panel 0: Members ── %>
  <div data-league-sidebar-target="panel"
       data-testid="sidebar-panel-members"
       data-open="false"
       style="width: 0; overflow: hidden; transition: width 0.25s ease;
              height: 100%; background: #12141e;
              border-left: 1px solid rgba(255,255,255,0.08);
              box-shadow: -4px 0 24px rgba(0,0,0,0.4);">
    <div style="width: 300px; padding: 1.25rem; box-sizing: border-box; overflow-y: auto; height: 100%;">

      <h3 style="margin: 0 0 1rem; font-size: 0.875rem; font-weight: 700; color: #EAECEF;
                 text-transform: uppercase; letter-spacing: 0.08em;">Members</h3>

      <%# Owner row %>
      <div style="display: flex; align-items: center; gap: 0.6rem; padding: 0.6rem 0;
                  border-bottom: 1px solid rgba(255,255,255,0.06);">
        <div style="width: 32px; height: 32px; background: rgba(240,185,11,0.2); border-radius: 50%;
                    display: flex; align-items: center; justify-content: center;
                    color: #14B8A6; font-size: 0.75rem; font-weight: 700; flex-shrink: 0;
                    border: 1px solid rgba(240,185,11,0.3);">
          <%= @league.owner.display_name.first.upcase %>
        </div>
        <div style="flex: 1; min-width: 0;">
          <div style="font-size: 0.82rem; font-weight: 600; color: #EAECEF;
                      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
            <%= @league.owner.display_name %>
          </div>
          <div style="font-size: 0.72rem; color: #929AA5; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
            <%= @league.owner.email %>
          </div>
        </div>
        <span style="font-size: 0.68rem; color: #14B8A6; font-weight: 700;
                     background: rgba(240,185,11,0.1); padding: 0.15rem 0.5rem; border-radius: 3px; flex-shrink: 0;">
          Owner
        </span>
      </div>

      <%# Other members %>
      <% other_members = @members.reject { |m| m.user_id == @league.owner_id } %>
      <% other_members.each do |membership| %>
        <div style="display: flex; align-items: center; gap: 0.6rem; padding: 0.6rem 0;
                    border-bottom: 1px solid rgba(255,255,255,0.06);">
          <div style="width: 32px; height: 32px; background: rgba(99,102,241,0.2); border-radius: 50%;
                      display: flex; align-items: center; justify-content: center;
                      color: #818cf8; font-size: 0.75rem; font-weight: 700; flex-shrink: 0;
                      border: 1px solid rgba(99,102,241,0.3);">
            <%= membership.user.display_name.first.upcase %>
          </div>
          <div style="flex: 1; min-width: 0;">
            <div style="font-size: 0.82rem; font-weight: 600; color: #EAECEF;
                        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
              <%= membership.user.display_name %>
            </div>
            <div style="font-size: 0.72rem; color: #929AA5; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
              <%= membership.user.email %>
            </div>
          </div>
        </div>
      <% end %>

      <%# Invite form (owner only) %>
      <% if current_user == @league.owner %>
        <div style="margin-top: 1.25rem; padding-top: 1rem; border-top: 1px solid rgba(255,255,255,0.08);">
          <p style="font-size: 0.78rem; font-weight: 700; color: #EAECEF; margin: 0 0 0.6rem;
                    text-transform: uppercase; letter-spacing: 0.06em;">Invite a Member</p>
          <%= form_with url: invite_league_path(@league), method: :post, style: "display: flex; gap: 0.4rem;" do |f| %>
            <%= f.text_field :identifier,
                  placeholder: "Email or display name",
                  class: "bnb-input",
                  style: "flex: 1; font-size: 0.8rem; padding: 0.45rem 0.6rem;" %>
            <%= f.submit "Invite",
                  class: "bnb-btn-primary",
                  style: "font-size: 0.8rem; padding: 0.45rem 0.8rem; flex-shrink: 0; margin-top: 5px" %>
          <% end %>
        </div>
      <% end %>

    </div>
  </div>

  <%# ── Panel 1: Details ── %>
  <div data-league-sidebar-target="panel"
       data-testid="sidebar-panel-details"
       data-open="false"
       style="width: 0; overflow: hidden; transition: width 0.25s ease;
              height: 100%; background: #12141e;
              border-left: 1px solid rgba(255,255,255,0.08);
              box-shadow: -4px 0 24px rgba(0,0,0,0.4);">
    <div style="width: 300px; padding: 1.25rem; box-sizing: border-box; overflow-y: auto; height: 100%;">

      <h3 style="margin: 0 0 1rem; font-size: 0.875rem; font-weight: 700; color: #EAECEF;
                 text-transform: uppercase; letter-spacing: 0.08em;">Details</h3>

      <dl style="font-size: 0.82rem; margin: 0; display: flex; flex-direction: column; gap: 0.75rem;">
        <% [
          ["Name",        @league.name],
          ["Description", @league.description.presence || "—"],
          ["Capital",     "$#{number_with_delimiter(@league.starting_capital.to_i)}"],
          ["Starts",      @league.starts_at.strftime("%Y-%m-%d %H:%M")],
          ["Ends",        @league.ends_at.strftime("%Y-%m-%d %H:%M")],
          ["Status",      @league.status.capitalize],
        ].each do |label, value| %>
          <div style="display: flex; flex-direction: column; gap: 0.15rem;
                      padding-bottom: 0.75rem; border-bottom: 1px solid rgba(255,255,255,0.05);">
            <dt style="font-weight: 700; color: #929AA5; font-size: 0.7rem;
                       text-transform: uppercase; letter-spacing: 0.08em;"><%= label %></dt>
            <dd style="margin: 0; color: #EAECEF;"><%= value %></dd>
          </div>
        <% end %>

        <% if current_user == @league.owner %>
          <div style="display: flex; flex-direction: column; gap: 0.15rem;">
            <dt style="font-weight: 700; color: #929AA5; font-size: 0.7rem;
                       text-transform: uppercase; letter-spacing: 0.08em;">Invite code</dt>
            <dd style="margin: 0; color: #14B8A6; font-family: monospace; font-size: 1rem; font-weight: 700;
                       letter-spacing: 0.1em;"><%= @league.invite_code %></dd>
          </div>
        <% end %>
      </dl>

      <% if current_user == @league.owner %>
        <div style="margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid rgba(255,255,255,0.08);">
          <%= button_to "Destroy League", @league, method: :delete,
                data: { turbo_confirm: "Are you sure? This cannot be undone." },
                style: "width: 100%; padding: 0.5rem; background: rgba(246,70,93,0.12);
                        color: #F6465D; border: 1px solid rgba(246,70,93,0.25); border-radius: 6px;
                        cursor: pointer; font-size: 0.82rem; font-weight: 600;
                        transition: background 0.2s;",
                onmouseover: "this.style.background='rgba(246,70,93,0.22)'"
                %>
        </div>
      <% end %>

    </div>
  </div>

  <%# ── Tab buttons (always visible on right edge) ── %>
  <div style="display: flex; flex-direction: column; height: 100%;">

    <button type="button"
            data-testid="sidebar-tab-members"
            data-action="click->league-sidebar#toggle"
            data-league-sidebar-index-param="0"
            style="writing-mode: vertical-rl; transform: rotate(180deg);
                   padding: 1.25rem 0.6rem; background: #1a1d2e; color: #929AA5;
                   border: none; border-bottom: 1px solid rgba(255,255,255,0.08);
                   border-left: 1px solid rgba(255,255,255,0.08);
                   cursor: pointer; font-size: 0.78rem; font-weight: 700;
                   letter-spacing: 0.08em; text-transform: uppercase; transition: color 0.2s;"
            onmouseover="this.style.color='#14B8A6'" onmouseout="this.style.color='#929AA5'">
      Members
    </button>

    <button type="button"
            data-testid="sidebar-tab-details"
            data-action="click->league-sidebar#toggle"
            data-league-sidebar-index-param="1"
            style="writing-mode: vertical-rl; transform: rotate(180deg);
                   padding: 1.25rem 0.6rem; background: #1a1d2e; color: #929AA5;
                   border: none; border-left: 1px solid rgba(255,255,255,0.08);
                   cursor: pointer; font-size: 0.78rem; font-weight: 700;
                   letter-spacing: 0.08em; text-transform: uppercase; transition: color 0.2s;"
            onmouseover="this.style.color='#14B8A6'" onmouseout="this.style.color='#929AA5'">
      Details
    </button>

  </div>
</div>
