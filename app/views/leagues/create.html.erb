<div style="min-height: calc(100vh - 64px); display: flex; align-items: center; justify-content: center; padding: 2rem;">
  <div style="text-align: center; max-width: 400px;">
    <div style="display: inline-flex; align-items: center; justify-content: center;
                width: 64px; height: 64px; background: rgba(46,189,133,0.12);
                border: 1px solid rgba(46,189,133,0.3); border-radius: 50%; font-size: 1.75rem; margin-bottom: 1.5rem;">
      ✓
    </div>
    <h1 class="tw-font-custom" style="color: #EAECEF; font-size: 1.75rem; letter-spacing: 0.1em;
                text-transform: uppercase; margin: 0 0 0.75rem;">League Created!</h1>
    <p style="color: #929AA5; font-size: 0.9rem; margin: 0 0 2rem;">
      Your league is ready. Share the invite code with friends to get started.
    </p>
    <%= link_to "View My Leagues →", leagues_path, class: "bnb-btn-primary",
        style: "text-decoration: none; padding: 0.85rem 2.5rem; font-size: 0.95rem;" %>
  </div>
</div>
