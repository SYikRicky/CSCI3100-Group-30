<div style="max-width: 1280px; margin: 0 auto; padding: 2.5rem 1.5rem;">

  <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
    <div>
      <h1 class="tw-font-custom" style="color: #EAECEF; font-size: 1.75rem; letter-spacing: 0.1em;
                  text-transform: uppercase; margin: 0 0 0.25rem;">My Leagues</h1>
      <p style="color: #929AA5; font-size: 0.82rem; margin: 0;">
        Manage your competitions or join one with an invite code.
      </p>
    </div>
    <div style="display: flex; gap: 0.75rem;">
      <button onclick="document.getElementById('join-modal').style.display='flex'"
              class="bnb-btn-ghost">Join with Code</button>
      <button onclick="document.getElementById('new-league-modal').style.display='flex'"
              class="bnb-btn-primary">+ New League</button>
    </div>
  </div>

  <div id="leagues" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1rem;">
    <% if @leagues.any? %>
      <% @leagues.each do |league| %>
        <%= render league %>
      <% end %>
    <% else %>
      <div style="grid-column: 1 / -1; background: rgba(255,255,255,0.04);
                  border: 1px solid rgba(255,255,255,0.08); border-radius: 12px;
                  padding: 4rem; text-align: center;">
        <p style="color: #929AA5; font-size: 0.95rem; margin: 0 0 0.5rem;">No leagues yet.</p>
        <p style="color: #929AA5; font-size: 0.82rem; margin: 0 0 1.5rem; opacity: 0.6;">
          Create your first league or join one with an invite code.
        </p>
        <div style="display: flex; gap: 0.75rem; justify-content: center;">
          <button onclick="document.getElementById('join-modal').style.display='flex'"
                  class="bnb-btn-ghost">Join with Code</button>
          <button onclick="document.getElementById('new-league-modal').style.display='flex'"
                  class="bnb-btn-primary">Create League</button>
        </div>
      </div>
    <% end %>
  </div>

</div>

<%# ── Join with Code Modal ── %>
<div id="join-modal"
     style="display: none; position: fixed; inset: 0; z-index: 200;
            background: rgba(0,0,0,0.75); align-items: center; justify-content: center; padding: 1.5rem;"
     onclick="if(event.target===this) this.style.display='none'">
  <div style="background: #12141e; border: 1px solid rgba(255,255,255,0.1);
              border-radius: 16px; padding: 2rem; width: 100%; max-width: 420px; position: relative;">

    <button onclick="document.getElementById('join-modal').style.display='none'"
            style="position: absolute; top: 1rem; right: 1rem; background: none; border: none;
                   color: #929AA5; font-size: 1.4rem; cursor: pointer; line-height: 1; padding: 0;"
            onmouseover="this.style.color='#EAECEF'" onmouseout="this.style.color='#929AA5'">&times;</button>

    <div style="text-align: center; margin-bottom: 1.75rem;">
      <div style="display: inline-flex; align-items: center; justify-content: center;
                  width: 48px; height: 48px; background: rgba(20,184,166,0.12);
                  border: 1px solid rgba(20,184,166,0.25); border-radius: 12px;
                  font-size: 1.4rem; margin-bottom: 0.75rem;">🔑</div>
      <h2 class="tw-font-custom" style="color: #EAECEF; font-size: 1.3rem; letter-spacing: 0.1em;
                  text-transform: uppercase; margin: 0 0 0.4rem;">Join a League</h2>
      <p style="color: #929AA5; font-size: 0.82rem; margin: 0;">Enter the invite code shared by the league owner.</p>
    </div>

    <div id="join-msg" style="display: none; border-radius: 8px; padding: 0.75rem 1rem;
                              margin-bottom: 1.25rem; font-size: 0.85rem; text-align: center;"></div>

    <%= form_with url: join_leagues_path, method: :post, id: "join-league-form", data: { turbo: false } do |form| %>
      <div style="margin-bottom: 1.25rem;">
        <%= form.label :invite_code,
            style: "display: block; color: #929AA5; font-size: 0.75rem; font-weight: 700;
                    text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.4rem;" %>
        <%= form.text_field :invite_code, placeholder: "e.g. ABC-123",
            class: "bnb-input",
            style: "text-transform: uppercase; letter-spacing: 0.15em; font-size: 1rem; font-weight: 700;" %>
      </div>
      <%= form.submit "Join League", id: "join-submit", class: "bnb-btn-primary",
          style: "width: 100%; padding: 0.85rem; font-size: 0.95rem;" %>
    <% end %>

  </div>
</div>

<%# ── New League Modal ── %>
<div id="new-league-modal"
     style="display: none; position: fixed; inset: 0; z-index: 200;
            background: rgba(0,0,0,0.75); align-items: center; justify-content: center; padding: 1.5rem;"
     onclick="if(event.target===this) this.style.display='none'">
  <div style="background: #12141e; border: 1px solid rgba(255,255,255,0.1);
              border-radius: 16px; padding: 2rem; width: 100%; max-width: 640px;
              max-height: 90vh; overflow-y: auto; position: relative;">

    <button onclick="document.getElementById('new-league-modal').style.display='none'"
            style="position: absolute; top: 1rem; right: 1rem; background: none; border: none;
                   color: #929AA5; font-size: 1.4rem; cursor: pointer; line-height: 1; padding: 0;"
            onmouseover="this.style.color='#EAECEF'" onmouseout="this.style.color='#929AA5'">&times;</button>

    <h2 class="tw-font-custom" style="color: #EAECEF; font-size: 1.3rem; letter-spacing: 0.1em;
                text-transform: uppercase; margin: 0 0 1.25rem;">New League</h2>

    <div id="new-league-msg" style="display: none; border-radius: 8px; padding: 0.75rem 1rem;
                                    margin-bottom: 1.25rem; font-size: 0.85rem; text-align: center;"></div>

    <%= render "form", league: @league %>

  </div>
</div>

<script>
(function () {
  const csrf = () => document.querySelector('meta[name="csrf-token"]').content;

  function showMsg(el, text, type) {
    el.textContent = text;
    el.style.display = 'block';
    if (type === 'success') {
      el.style.background = 'rgba(46,189,133,0.12)';
      el.style.border     = '1px solid rgba(46,189,133,0.3)';
      el.style.color      = '#2EBD85';
    } else {
      el.style.background = 'rgba(246,70,93,0.12)';
      el.style.border     = '1px solid rgba(246,70,93,0.3)';
      el.style.color      = '#F6465D';
    }
  }

  function ajaxForm(formId, msgId, submitId) {
    const form   = document.getElementById(formId);
    const msgEl  = document.getElementById(msgId);
    const submit = document.getElementById(submitId);
    if (!form) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      submit.disabled    = true;
      submit.textContent = 'Please wait…';
      msgEl.style.display = 'none';

      try {
        const resp = await fetch(form.action, {
          method:  form.method.toUpperCase(),
          body:    new FormData(form),
          headers: { 'Accept': 'application/json', 'X-CSRF-Token': csrf() }
        });
        const data = await resp.json();

        if (resp.ok) {
          showMsg(msgEl, data.notice, 'success');
          form.reset();
          if (data.url) {
            setTimeout(() => { window.location.href = data.url; }, 800);
          } else {
            setTimeout(() => { window.location.reload(); }, 800);
          }
        } else {
          const msg = data.error || (data.errors && data.errors.join(', ')) || 'Something went wrong.';
          showMsg(msgEl, msg, 'error');
        }
      } catch (_) {
        showMsg(msgEl, 'Network error. Please try again.', 'error');
      } finally {
        submit.disabled    = false;
        submit.textContent = submitId === 'join-submit' ? 'Join League' : 'Create League';
      }
    });
  }

  ajaxForm('join-league-form',  'join-msg',        'join-submit');
  ajaxForm('new-league-form',   'new-league-msg',  'new-league-submit');
})();
</script>
