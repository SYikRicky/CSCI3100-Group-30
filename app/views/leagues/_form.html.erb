<%= form_with(model: league, data: { controller: "invite-popup" }) do |form| %>
  <% if league.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(league.errors.count, "error") %> prohibited this league from being saved:</h2>
      <ul>
        <% league.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :description, style: "display: block" %>
    <%= form.text_field :description %>
  </div>

  <div>
    <%= form.label :starting_capital, style: "display: block" %>
    <%= form.text_field :starting_capital %>
  </div>

  <div>
    <%= form.label :starts_at, style: "display: block" %>
    <%= form.datetime_local_field :starts_at %>
  </div>

  <div>
    <%= form.label :ends_at, style: "display: block" %>
    <%= form.datetime_local_field :ends_at %>
  </div>

  <%# ── Invite field ── %>
  <div>
    <%= form.label :invitee_identifier, "Invitee (optional — email or username)", style: "display: block" %>
    <div style="display: flex; gap: 0.5rem; align-items: center">
      <%= form.text_field :invitee_identifier,
            placeholder: "Email or display name",
            data: { "invite-popup-target": "input" } %>
      <button data-action="invite-popup#open">Browse Friends</button>
    </div>
  </div>

  <%# ── Friend-picker popup ── %>
  <div data-invite-popup-target="popup"
       class="hidden"
       data-action="click->invite-popup#backdropClose"
       style="position: fixed; inset: 0; background: rgba(0,0,0,0.4);
              display: flex; align-items: center; justify-content: center; z-index: 50">
    <div style="background: white; border-radius: 8px; padding: 1.5rem;
                width: 360px; max-height: 70vh; overflow-y: auto">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem">
        <h3 style="margin: 0">Invite a Friend</h3>
        <button data-action="invite-popup#close" aria-label="Close">&times;</button>
      </div>

      <%# Mirror the same input inside the popup for typing %>
      <input type="text"
             placeholder="Email or display name"
             data-invite-popup-target="input"
             style="width: 100%; margin-bottom: 1rem; padding: 0.4rem"
             oninput="this.closest('[data-controller]').querySelector('[data-invite-popup-target=input]:not(this)').value = this.value" />

      <% if defined?(@friends) && @friends.any? %>
        <ul style="list-style: none; margin: 0; padding: 0">
          <% @friends.each do |friend| %>
            <li style="margin-bottom: 0.5rem">
              <button data-action="invite-popup#select"
                      data-value="<%= friend.email %>"
                      style="width: 100%; text-align: left; padding: 0.5rem;
                             border: 1px solid #ddd; border-radius: 4px; cursor: pointer">
                <strong><%= friend.display_name %></strong>
                <span style="color: gray; font-size: 0.85em"><%= friend.email %></span>
              </button>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p style="color: gray">No friends yet. Add friends from <a href="<%= friendships_path %>">your friends page</a>.</p>
      <% end %>
    </div>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
