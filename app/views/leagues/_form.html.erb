<%= form_with(model: league, id: "new-league-form", data: { controller: "invite-popup", turbo: false }) do |form| %>
  <% if league.errors.any? %>
    <div style="background: rgba(246,70,93,0.1); border: 1px solid rgba(246,70,93,0.25);
                border-radius: 8px; padding: 1rem 1.25rem; margin-bottom: 1.5rem;">
      <p style="color: #F6465D; font-size: 0.85rem; font-weight: 700; margin: 0 0 0.4rem;">
        <%= pluralize(league.errors.count, "error") %> prevented this league from being saved:
      </p>
      <ul style="color: #F6465D; font-size: 0.82rem; margin: 0; padding-left: 1.25rem; opacity: 0.85;">
        <% league.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% [
    { field: :name,             label: "League Name",       type: :text_field },
    { field: :description,      label: "Description",       type: :text_field },
    { field: :starting_capital, label: "Starting capital", type: :text_field },
    { field: :starts_at,        label: "Starts at",         type: :datetime_local_field },
    { field: :ends_at,          label: "Ends at",           type: :datetime_local_field },
  ].each do |f| %>
    <div style="margin-bottom: 1.25rem;">
      <%= form.label f[:field], f[:label],
          style: "display: block; color: #929AA5; font-size: 0.75rem; font-weight: 700;
                  text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.4rem;" %>
      <%= form.send(f[:type], f[:field], class: "bnb-input") %>
    </div>
  <% end %>

  <%# ── Multi-invitee tags field ── %>
  <div style="margin-bottom: 1.25rem;">
    <label style="display: block; color: #929AA5; font-size: 0.75rem; font-weight: 700;
                  text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.4rem;">
      Invitees <span style="color: #929AA5; font-weight: 400; text-transform: none; letter-spacing: normal;">(optional)</span>
    </label>

    <%# Chip display area %>
    <div data-invite-popup-target="tags"
         style="display: flex; flex-wrap: wrap; gap: 0.4rem; min-height: 2.4rem;
                border: 1px solid rgba(255,255,255,0.12); border-radius: 6px; padding: 0.4rem;
                background: rgba(255,255,255,0.07); margin-bottom: 0.5rem;">
    </div>

    <%# Hidden field for Stimulus %>
    <input type="hidden"
           id="league_invitee_identifiers_raw"
           name="league[invitee_identifiers_raw]"
           data-invite-popup-target="rawField" />

    <%# Input row %>
    <div style="display: flex; gap: 0.5rem; align-items: center;">
      <input type="text"
             data-invite-popup-target="input"
             placeholder="Email or display name"
             class="bnb-input"
             style="flex: 1;" />
      <button type="button"
              data-action="invite-popup#addTag"
              class="bnb-btn-ghost"
              style="padding: 0.55rem 0.9rem; white-space: nowrap;">
        Add
      </button>
      <button type="button"
              data-action="invite-popup#open"
              class="bnb-btn-ghost"
              style="padding: 0.55rem 0.9rem; white-space: nowrap;">
        Browse
      </button>
    </div>
  </div>

  <%# ── Friend-picker popup ── %>
  <div data-invite-popup-target="popup"
       data-action="click->invite-popup#backdropClose"
       style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7);
              align-items: center; justify-content: center; z-index: 50;">
    <div style="background: #12141e; border: 1px solid rgba(255,255,255,0.1);
                border-radius: 12px; padding: 1.5rem; width: 380px; max-height: 70vh; overflow-y: auto;">

      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.25rem;">
        <h3 style="margin: 0; color: #EAECEF; font-size: 1rem; font-weight: 700;">Browse Friends</h3>
        <button type="button"
                data-action="invite-popup#close"
                aria-label="Close"
                style="background: none; border: none; font-size: 1.4rem; cursor: pointer;
                       line-height: 1; color: #929AA5; transition: color 0.2s;"
                onmouseover="this.style.color='#EAECEF'" onmouseout="this.style.color='#929AA5'">
          &times;
        </button>
      </div>

      <% if defined?(@friends) && @friends.any? %>
        <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem;">
          <% @friends.each do |friend| %>
            <li>
              <button type="button"
                      data-action="invite-popup#select"
                      data-value="<%= friend.email %>"
                      style="width: 100%; text-align: left; padding: 0.65rem 0.75rem;
                             border: 1px solid rgba(255,255,255,0.08); border-radius: 8px;
                             cursor: pointer; background: rgba(255,255,255,0.04); color: #EAECEF;
                             transition: border-color 0.2s, background 0.2s;"
                      onmouseover="this.style.borderColor='rgba(240,185,11,0.3)'; this.style.background='rgba(240,185,11,0.06)'"
                      onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'; this.style.background='rgba(255,255,255,0.04)'">
                <strong style="font-size: 0.875rem;"><%= friend.display_name %></strong>
                <span style="color: #929AA5; font-size: 0.8rem; margin-left: 0.4rem;"><%= friend.email %></span>
              </button>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p style="color: #929AA5; margin: 0; font-size: 0.875rem;">
          No friends yet.
          <%= link_to "Add friends", friendships_path, style: "color: #14B8A6; text-decoration: none;" %>
        </p>
      <% end %>
    </div>
  </div>

  <div style="margin-top: 1.75rem; padding-top: 1.25rem; border-top: 1px solid rgba(255,255,255,0.07);">
    <%= form.submit id: "new-league-submit", class: "bnb-btn-primary",
        style: "width: 100%; padding: 0.85rem; font-size: 0.95rem; border-radius: 6px;" %>
  </div>
<% end %>
