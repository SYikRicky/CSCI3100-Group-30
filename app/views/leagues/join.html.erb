<div style="min-height: calc(100vh - 64px); display: flex; align-items: center; justify-content: center; padding: 2rem 1.5rem;">
  <div style="width: 100%; max-width: 420px;">

    <div style="text-align: center; margin-bottom: 2rem;">
      <div style="display: inline-flex; align-items: center; justify-content: center;
                  width: 52px; height: 52px; background: rgba(240,185,11,0.12);
                  border: 1px solid rgba(240,185,11,0.25); border-radius: 12px;
                  font-size: 1.5rem; margin-bottom: 1rem;">🔑</div>
      <h1 class="tw-font-custom" style="color: #EAECEF; font-size: 1.6rem; letter-spacing: 0.1em;
                  text-transform: uppercase; margin: 0 0 0.5rem;">Join a League</h1>
      <p style="color: #929AA5; font-size: 0.875rem; margin: 0;">Enter the invite code shared by the league owner.</p>
    </div>

    <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
                border-radius: 12px; padding: 2rem;">

      <% if flash[:alert] %>
        <div style="background: rgba(246,70,93,0.1); border: 1px solid rgba(246,70,93,0.25);
                    border-radius: 8px; padding: 0.75rem 1rem; margin-bottom: 1.25rem;">
          <p style="color: #F6465D; font-size: 0.85rem; margin: 0;"><%= flash[:alert] %></p>
        </div>
      <% end %>

      <%= form_with url: join_leagues_path, method: :post do |form| %>
        <div style="margin-bottom: 1.25rem;">
          <%= form.label :invite_code,
              style: "display: block; color: #929AA5; font-size: 0.75rem; font-weight: 700;
                      text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.4rem;" %>
          <%= form.text_field :invite_code, placeholder: "e.g. ABC-123",
              class: "bnb-input",
              style: "text-transform: uppercase; letter-spacing: 0.15em; font-size: 1rem; font-weight: 700;" %>
        </div>
        <%= form.submit "Join League", class: "bnb-btn-primary",
            style: "width: 100%; padding: 0.85rem; font-size: 0.95rem;" %>
      <% end %>

    </div>

    <div style="text-align: center; margin-top: 1.25rem;">
      <%= link_to "← Back to Leagues", leagues_path,
          style: "color: #929AA5; text-decoration: none; font-size: 0.82rem;",
          onmouseover: "this.style.color='#EAECEF'", onmouseout: "this.style.color='#929AA5'" %>
    </div>

  </div>
</div>
