<!DOCTYPE html>
<html>
  <head>
    <title>Mock Fund League</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Saira+Stencil+One&display=swap" rel="stylesheet">

    <style>
      .bnb-yellow        { color: #14B8A6; }
      .bnb-bg-yellow     { background-color: #14B8A6; }
      .bnb-bg-yellow:hover { background-color: #d4a409; }
      .bnb-green         { color: #2EBD85; }
      .bnb-red           { color: #F6465D; }
      .bnb-card          { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); }
      .bnb-card:hover    { background: rgba(255,255,255,0.07); }
      .bnb-input         { background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12);
                           color: #EAECEF; border-radius: 6px; padding: 0.6rem 1rem; width: 100%;
                           font-size: 0.875rem; outline: none; transition: border-color 0.2s; }
      .bnb-input::placeholder { color: rgba(255,255,255,0.25); }
      .bnb-input:focus   { border-color: #14B8A6; }
      .bnb-btn-primary   { background-color: #14B8A6; color: #181A20; font-weight: 700;
                           border: none; border-radius: 6px; cursor: pointer; transition: background 0.2s;
                           font-size: 0.875rem; padding: 0.65rem 1.5rem; }
      .bnb-btn-primary:hover { background-color: #d4a409; }
      .bnb-btn-ghost     { background: transparent; color: #EAECEF; border: 1px solid rgba(255,255,255,0.2);
                           border-radius: 6px; cursor: pointer; font-size: 0.875rem;
                           padding: 0.6rem 1.25rem; transition: border-color 0.2s, background 0.2s; }
      .bnb-btn-ghost:hover { border-color: #14B8A6; color: #14B8A6; background: rgba(240,185,11,0.05); }
      .bnb-table tr:hover td { background: rgba(255,255,255,0.03); }
      .flash-bar         { position: fixed; top: 64px; left: 50%; transform: translateX(-50%);
                           z-index: 9999; padding: 0.6rem 1.5rem; border-radius: 8px;
                           font-size: 0.85rem; white-space: nowrap; backdrop-filter: blur(8px); }
      .flash-notice      { background: rgba(46,189,133,0.15); border: 1px solid rgba(46,189,133,0.3);
                           color: #2EBD85; }
      .flash-alert       { background: rgba(246,70,93,0.15); border: 1px solid rgba(246,70,93,0.3);
                           color: #F6465D; }
    </style>
  </head>

  <body class="tw-bg-gradient-to-br tw-from-indigo-950 tw-via-slate-950 tw-to-black tw-min-h-screen" style="color: #EAECEF; font-family: Arial, sans-serif;">

    <%# ── Binance-style top navigation ── %>
    <nav data-testid="main-nav"
         style="position: fixed; top: 0; left: 0; right: 0; z-index: 999;
                background: rgba(15,17,26,0.85); backdrop-filter: blur(16px);
                border-bottom: 1px solid rgba(255,255,255,0.07); height: 64px;
                display: flex; align-items: center;">
      <div style="max-width: 1280px; margin: 0 auto; padding: 0 1.5rem;
                  width: 100%; display: flex; align-items: center; gap: 2rem;">

        <%= link_to root_path, style: "display: flex; align-items: center; gap: 0.6rem; text-decoration: none; flex-shrink: 0;" do %>
          <%= image_tag "logo.png", alt: "MFL Logo",
              style: "width: 36px; height: 36px; object-fit: contain;" %>
          <span class="tw-font-custom" style="color: #EAECEF; font-size: 1rem; letter-spacing: 0.1em;">Mock Fund League</span>
        <% end %>

        <% if user_signed_in? %>
          <div style="display: flex; align-items: center; gap: 0.25rem; flex: 1;">
            <%= link_to "Markets", stocks_path,
                style: "color: #929AA5; text-decoration: none; font-size: 0.875rem; font-weight: 500;
                        padding: 0.4rem 0.75rem; border-radius: 4px; transition: color 0.2s;",
                onmouseover: "this.style.color='#EAECEF'", onmouseout: "this.style.color='#929AA5'" %>
            <%= link_to "Leagues", leagues_path,
                style: "color: #929AA5; text-decoration: none; font-size: 0.875rem; font-weight: 500;
                        padding: 0.4rem 0.75rem; border-radius: 4px; transition: color 0.2s;",
                onmouseover: "this.style.color='#EAECEF'", onmouseout: "this.style.color='#929AA5'" %>
            <%= link_to "Friends", friendships_path,
                style: "color: #929AA5; text-decoration: none; font-size: 0.875rem; font-weight: 500;
                        padding: 0.4rem 0.75rem; border-radius: 4px; transition: color 0.2s;",
                onmouseover: "this.style.color='#EAECEF'", onmouseout: "this.style.color='#929AA5'" %>
            <%= link_to "Chatroom", chatrooms_path,
                style: "color: #929AA5; text-decoration: none; font-size: 0.875rem; font-weight: 500;
                        padding: 0.4rem 0.75rem; border-radius: 4px; transition: color 0.2s;",
                onmouseover: "this.style.color='#EAECEF'", onmouseout: "this.style.color='#929AA5'" %>
          </div>
        <% else %>
          <div style="flex: 1;"></div>
        <% end %>

        <div style="display: flex; align-items: center; gap: 0.75rem; flex-shrink: 0; position: relative;">
          <% if user_signed_in? %>

            <%# Friend panel button %>
            <button data-testid="friend-panel-btn"
                    onclick="var p=document.getElementById('friend-panel');p.style.display=p.style.display==='none'?'block':'none'"
                    style="background: none; border: none; cursor: pointer; color: #929AA5;
                           font-size: 0.8rem; padding: 0.4rem 0.6rem; border-radius: 4px; transition: color 0.2s;"
                    onmouseover="this.style.color='#EAECEF'" onmouseout="this.style.color='#929AA5'">
              Friends
            </button>

            <%# Friend panel dropdown %>
            <div id="friend-panel" data-testid="friend-panel"
                 style="display: none; position: absolute; top: 48px; right: 120px; z-index: 1000;
                        background: #12141e; border: 1px solid rgba(255,255,255,0.1);
                        border-radius: 10px; padding: 1rem; min-width: 200px; max-height: 300px; overflow-y: auto;">
              <p style="color: #929AA5; font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
                        letter-spacing: 0.08em; margin: 0 0 0.75rem;">Friends</p>
              <% if current_user.friends.any? %>
                <% current_user.friends.each do |friend| %>
                  <div style="padding: 0.4rem 0; border-bottom: 1px solid rgba(255,255,255,0.05);
                              font-size: 0.82rem; color: #EAECEF;">
                    <%= friend.email %>
                  </div>
                <% end %>
              <% else %>
                <p style="color: #929AA5; font-size: 0.82rem; margin: 0;">No friends yet.</p>
              <% end %>
            </div>

            <%# Mailbox button %>
            <button data-testid="mailbox-btn"
                    onclick="var d=document.getElementById('mailbox-dropdown');d.style.display=d.style.display==='none'?'block':'none'"
                    style="background: none; border: none; cursor: pointer; color: #929AA5;
                           font-size: 1rem; padding: 0.4rem 0.5rem; border-radius: 4px;
                           position: relative; transition: color 0.2s;"
                    onmouseover="this.style.color='#EAECEF'" onmouseout="this.style.color='#929AA5'">
              ✉
              <% if @notifications&.any? %>
                <span style="position: absolute; top: 2px; right: 2px; width: 7px; height: 7px;
                             background: #F6465D; border-radius: 50%; display: block;"></span>
              <% end %>
            </button>

            <%# Mailbox dropdown %>
            <div id="mailbox-dropdown" data-testid="mailbox-dropdown"
                 style="display: none; position: absolute; top: 48px; right: 60px; z-index: 1000;
                        background: #12141e; border: 1px solid rgba(255,255,255,0.1);
                        border-radius: 10px; padding: 1rem; min-width: 280px; max-height: 360px; overflow-y: auto;">
              <p style="color: #929AA5; font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
                        letter-spacing: 0.08em; margin: 0 0 0.75rem;">Notifications</p>
              <% if @notifications&.any? %>
                <% @notifications.each do |n| %>
                  <div style="padding: 0.6rem 0; border-bottom: 1px solid rgba(255,255,255,0.06);">
                    <p style="color: #EAECEF; font-size: 0.82rem; font-weight: 600; margin: 0 0 0.2rem;">
                      <%= n.title %>
                    </p>
                    <p style="color: #929AA5; font-size: 0.78rem; margin: 0;"><%= n.body %></p>
                  </div>
                <% end %>
              <% else %>
                <p style="color: #929AA5; font-size: 0.82rem; margin: 0;">No notifications</p>
              <% end %>
            </div>

            <span style="color: #929AA5; font-size: 0.8rem;"><%= current_user.display_name %></span>
            <%= button_to "Log Out", destroy_user_session_path, method: :delete,
                class: "bnb-btn-ghost", style: "font-size: 0.8rem; padding: 0.4rem 0.9rem; border: none; cursor: pointer;" %>
          <% else %>
            <%= link_to "Log In", new_user_session_path, class: "bnb-btn-ghost" %>
            <%= link_to "Get Started", new_user_registration_path, class: "bnb-btn-primary" %>
          <% end %>
        </div>

      </div>
    </nav>

    <%# ── Flash messages ── %>
    <% if flash[:notice] %>
      <div class="flash-bar flash-notice"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
      <div class="flash-bar flash-alert"><%= flash[:alert] %></div>
    <% end %>

    <main style="padding-top: 64px;">
      <%= yield %>
    </main>

  </body>
</html>
